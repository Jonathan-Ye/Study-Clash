# ============================================
# Study Clash 生产环境配置模板
# ============================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 修改下方配置项
# 3. Docker 部署时会自动读取 .env 文件

# 运行模式 (生产环境必须为 production)
FLASK_ENV=production

# 应用密钥 (必填! 必须使用随机生成的64位字符串)
# 生成命令: openssl rand -hex 32
# 或在 Python 中运行: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=请替换为生成的随机密钥

# ============================================
# 数据库配置
# ============================================

# PostgreSQL 数据库配置（生产和本地开发统一使用）
# 本地开发环境配置（需要先安装并启动 PostgreSQL）:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studyclash_dev
#
# Docker Compose 部署时，数据库服务名默认为 db:
#   DATABASE_URL=postgresql://postgres:密码@db:5432/studyclash

# Docker 部署时的数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=studyclash_db_password  # 请修改为强密码（不能包含 $ @ : / 等字符）
POSTGRES_DB=studyclash

# ============================================
# 其他配置
# ============================================

# AI 大模型加密密钥（用于加密存储 API 密钥）
# 生成命令: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 或在 Python 中运行: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
LLM_ENCRYPTION_KEY=

# WebSocket 跨域设置
# 如果通过IP访问: http://服务器IP:5002
# 如果有域名: http://your-domain.com,https://your-domain.com
# 如果不确定: * (允许所有来源)
SOCKETIO_CORS_ALLOWED_ORIGINS=*

# 日志配置
LOG_DIR=logs
LOG_RETENTION_DAYS=30
