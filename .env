FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# 数据库配置（本地开发使用 PostgreSQL）
# 本地 PostgreSQL 连接（需要先安装并启动 PostgreSQL）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/studyclash_dev

# 日志配置
# 日志文件存储目录（相对于项目根目录）
LOG_DIR=logs
# 日志保留天数（超时自动删除）
LOG_RETENTION_DAYS=30

# AI大模型加密密钥（用于加密存储API密钥，请勿随意更改否则已加密的密钥将无法解密）
LLM_ENCRYPTION_KEY=-KcSJhV6XUt7gqCIi-Dg36ynSUS4xnsyf_OdpMm8W3A=

# 自动生成的环境变量
SOCKETIO_CORS_ALLOWED_ORIGINS=*
